  <main class="app-shell">
    <header class="studio-topbar">
      <div class="topbar-row">
        <button type="button" class="btn secondary topbar-prev" data-action="back">חזרה לשלב הקודם</button>
        <button type="button" class="btn primary topbar-next" data-action="next">המשך לשלב הבא</button>
      </div>
      <div class="progress" id="progress"></div>
    </header>

    <section class="step active" data-step="0">
      <h2>בחירת קטגוריית מוצר</h2>
      <p class="step-sub">בחרו קטגוריה וצפו בקטלוג מוצרים אופקי בסגנון פרימיום.</p>
      <div class="chip-row" id="categoryChips"></div>
      <div id="catalogSections"></div>
    </section>

    <section class="step" data-step="1">
      <div class="custom-layout">
        <div class="viewer">
          <h3>תצוגת סטודיו</h3>
          <div class="stage">
            <div class="mock-product" id="mockProduct">
              <div class="mock-engrave-surface" id="mockEngraveSurface"></div>
            </div>
          </div>
        </div>
        <aside class="panel">
          <div class="panel-title-row">
            <h4>עמוד עיצוב</h4>
          </div>
          <div class="engrave-header">
            <label class="engrave-main-label">טקסט לחריטה</label>
            <button class="add-text-btn" type="button" id="addTextBlock" aria-label="הוספת שורת טקסט">+</button>
          </div>
          <div id="textBlocks"></div>
          <div class="form-grid form-grid-studio">
            <label>פונט<select id="fontSelect"></select></label>
            <label>גודל<input id="textSize" type="range" min="16" max="50" /></label>
            <label>מיקום
              <select id="positionSelect">
                <option value="top">עליון</option>
                <option value="center" selected>מרכז</option>
                <option value="bottom">תחתון</option>
              </select>
            </label>
            <label>יישור<select id="alignSelect"><option value="right">ימין</option><option value="center">מרכז</option><option value="left">שמאל</option></select></label>
          </div>
          <div class="field-group">
            <div class="engrave-header">
              <span class="field-title engrave-inline-title">אימוג׳ים וסימנים</span>
              <button class="add-text-btn" type="button" id="addEmojiBlock" aria-label="הוספת סימן">+</button>
            </div>
            <div id="emojiBlocks"></div>
            <div id="emojiPicker" class="emoji-picker"></div>
            <p class="field-hint">בחרו סימן לכל שורה או פתחו את בוחר האימוג׳י; בתצוגה אפשר לגרור כל סימן בנפרד.</p>
          </div>
          <div class="field-group">
            <span class="field-title">בחירת צבעים</span>
            <div class="opt-row colors-row" id="materials"></div>
          </div>
          <div class="field-group">
            <span class="field-title">מידות</span>
            <div class="opt-row sizes-row" id="sizes"></div>
          </div>
          <div class="field-group field-group-qty">
            <label>כמות<input id="qtyInput" type="number" min="1" /></label>
          </div>
          <div class="form-grid">
            <label>אריזת מתנה<select id="giftWrap"><option value="false">ללא</option><option value="true">כן, בתוספת ₪14</option></select></label>
            <label>תוספת מיוחדת
              <select id="extraAddon">
                <option value="none">ללא</option>
                <option value="priority">תיעדוף ייצור (+₪19)</option>
                <option value="doubleEngrave">חריטה כפולה (+₪29)</option>
              </select>
            </label>
          </div>
          <label>הערות מיוחדות<textarea id="notesInput" rows="2"></textarea></label>
        </aside>
      </div>
    </section>

    <section class="step" data-step="2">
      <div class="checkout-layout">
        <div class="panel">
          <h3>משלוח ותשלום</h3>
          <div class="form-grid" id="checkoutFields"></div>
          <h4>קופון</h4>
          <div id="couponBox" class="coupon-box"></div>
          <h4>שיטת משלוח</h4>
          <div class="ship-row" id="shippingMethods"></div>
          <h4>תשלום (דמה)</h4>
          <div class="wallet-menu-wrap">
            <button type="button" class="wallet-menu-trigger" id="walletMenuTrigger" aria-haspopup="listbox" aria-expanded="false">
              <span class="wallet-trigger-inner" id="walletTriggerInner"></span>
              <span class="wallet-chevron" aria-hidden="true">▾</span>
            </button>
            <div class="wallet-menu" id="walletMenu" role="listbox" hidden></div>
          </div>
          <p class="wallet-mock-hint" id="walletMockHint" hidden>בדמו: ההמשך יתבצע דרך הארנק שנבחר.</p>
          <div class="form-grid" id="cardFieldsGrid">
            <label>שם בעל הכרטיס<input data-checkout="cardName" /></label>
            <label>מספר כרטיס<input data-checkout="cardNumber" placeholder="4580 0000 0000 0000" /></label>
            <label>תוקף<input data-checkout="expiry" placeholder="12/29" /></label>
            <label>CVV<input data-checkout="cvv" /></label>
          </div>
        </div>
        <aside class="panel" id="orderSummary"></aside>
      </div>
    </section>

    <section class="step" data-step="3">
      <div class="success">
        <div class="success-icon">✓</div>
        <h2>התשלום התקבל בהצלחה</h2>
        <p>הזמנתך נקלטה ותעבור לייצור בקרוב.</p>
        <div class="summary-card" id="finalSummary"></div>
        <ul class="timeline timeline-stepper" role="list" aria-label="סטטוס הזמנה">
          <li class="timeline-step timeline-step--done">
            <div class="timeline-track">
              <span class="timeline-marker timeline-marker--check" aria-hidden="true">✓</span>
            </div>
            <span class="timeline-label">התקבלה הזמנה</span>
          </li>
          <li class="timeline-step">
            <div class="timeline-track">
              <span class="timeline-marker timeline-marker--dot" aria-hidden="true"></span>
            </div>
            <span class="timeline-label">עוברת לבדיקה</span>
          </li>
          <li class="timeline-step">
            <div class="timeline-track">
              <span class="timeline-marker timeline-marker--dot" aria-hidden="true"></span>
            </div>
            <span class="timeline-label">בייצור</span>
          </li>
          <li class="timeline-step">
            <div class="timeline-track">
              <span class="timeline-marker timeline-marker--dot" aria-hidden="true"></span>
            </div>
            <span class="timeline-label">מוכנה למשלוח</span>
          </li>
        </ul>
        <div class="nav-actions">
          <a class="back-link back-link--footer" href="{{ routes.root_url }}">
            <span class="back-link-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>
            </span>
            <span class="back-link-text">חזרה לאתר</span>
          </a>
          <button class="btn secondary" data-action="restart">עצב מוצר נוסף</button>
          <button class="btn primary">הורד סיכום הזמנה</button>
        </div>
      </div>
    </section>

    <footer class="nav-footer" id="flowNav">
      <a class="back-link nav-footer-site" href="{{ routes.root_url }}">
        <span class="back-link-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>
        </span>
        <span class="back-link-text">חזרה לאתר</span>
      </a>
      <a
        class="studio-whatsapp-nav"
        href="https://wa.me/972559433968"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="שליחת הודעה בווצאפ"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>ווצאפ</span>
      </a>
    </footer>
  </main>
